@{
    Layout = "_Layout";
}

<div class="bill-container">
    <!-- Header Section -->
    <div class="header">
        <h1 class="company-name">Your Company Name</h1>
        <p class="date">Date: @DateTime.Now.ToString("MM/dd/yyyy")</p>
    </div>

    <!-- Customer Information Section -->
    <div class="customer-info">
        <h2>Customer Information</h2>
        <p><strong>Customer ID:</strong> @Model.CustomerId</p>
        <p><strong>Name:</strong> @Model.CustomerName</p>
        <p><strong>Address:</strong> @Model.CustomerAddress</p>
        <p><strong>Phone Number:</strong> @Model.CustomerPhone</p>
        <p><strong>Payment Method:</strong> @Model.PaymentMethod</p>
    </div>

    <!-- Product Information Section -->
    <div class="product-info">
        <h2>Product Information</h2>
        <table class="table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Product Name</th>
                    <th>Quantity</th>
                    <th>Amount</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model.Products)
                {
                    <tr>
                        <td>@product.SerialNumber</td>
                        <td>@product.ProductName</td>
                        <td>@product.Quantity</td>
                        <td>@product.Price.ToString("C")</td>
                        <td>@(product.Quantity * product.Price).ToString("C")</td>
                    </tr>
                }
            </tbody>
        </table>

        <p><strong>Total Amount:</strong> @Model.TotalAmount.ToString("C")</p>
        @if (Model.PaymentMethod != "Cash on Delivery")
        {
            <p><strong>Amount Paid:</strong> @Model.TotalAmount.ToString("C")</p>
        }
        else
        {
            <p><strong>Payment Method:</strong> Cash on Delivery</p>
        }
    </div>

    <!-- Signatures Section -->
    <div class="signatures">
        <div class="signature-left">
            <p><strong>Seller's Signature:</strong></p>
            <p>__________________________</p>
            <p><strong>Seller's Name:</strong> Nafees Al Mahadi</p>
        </div>
        <div class="signature-right">
            <p><strong>Customer's Signature:</strong></p>
            <p>__________________________</p>
        </div>
    </div>

    <!-- Footer Section -->
    <div class="footer">
        <p>Thank you for shopping with us!</p>
    </div>
</div>

<!-- Button to Generate PDF -->
<form method="post" action="@Url.Action("DownloadPDF", "Home", new { orderId = Model.OrderID })">
    <button type="submit" class="btn btn-success">Download PDF</button>
</form>

<style>
    .bill-container {
        font-family: Arial, sans-serif;
        width: 80%;
        margin: 0 auto;
        border: 1px solid #ccc;
        padding: 20px;
        background-color: #f9f9f9;
    }

    .header {
        text-align: center;
        margin-bottom: 30px;
    }

    .company-name {
        font-size: 24px;
        font-weight: bold;
    }

    .date {
        text-align: right;
        font-size: 14px;
    }

    .customer-info, .product-info {
        margin-bottom: 30px;
    }

    .product-info table {
        width: 100%;
        border-collapse: collapse;
    }

    .product-info th, .product-info td {
        padding: 8px;
        text-align: left;
        border: 1px solid #ccc;
    }

    .signatures {
        display: flex;
        justify-content: space-between;
        margin-top: 30px;
    }

    .signature-left, .signature-right {
        width: 45%;
        text-align: center;
    }

    .footer {
        text-align: center;
        margin-top: 40px;
        font-size: 14px;
    }
</style>
